# ─── Required ────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ─── Engine auth (fill what you need - engines check automatically) ──
# At least one key is required for its engine to be available.
# ANTHROPIC_API_KEY=              # Claude Code + OpenCode
# CLAUDE_CODE_OAUTH_TOKEN=        # Claude Code (Pro/Max plan)
# OPENAI_API_KEY=                 # OpenCode

# Tower API auth (empty = no auth)
# TOWER_API_KEY=

# ─── Scaling ─────────────────────────────────────────────────
# TOWER_PORT=8420
# TOWER_REPLICAS=1
# MAX_CONCURRENT_JOBS=10
# POOL_SIZE=3
# POOL_CHECK_INTERVAL=10
# POOL_MAX_IDLE=3600

# ─── Worker limits ───────────────────────────────────────────
# WORKER_TIMEOUT_SECONDS=3600
# WORKER_MEM_LIMIT=2g
# WORKER_CPU_LIMIT=1.0
# WORKER_RUNTIME=                  # gVisor: set to "runsc" (requires gVisor on host)
# WORKER_IMAGE=agent-worker-worker
# WORKER_NET=agent-workers
# UI_PATH=/app/ui/index.html

# ─── Jobs ────────────────────────────────────────────────────
# JOB_TTL_HOURS=24
# MAX_RETAINED_JOBS=1000
# CLEANUP_INTERVAL=600
# WEBHOOK_TIMEOUT=10
# MAX_RESULT_SIZE=10485760

# ─── LLM Gateway (always enabled - hides API keys from workers) ──
# GATEWAY_URL=http://agent-gateway:4000
# GATEWAY_CONTAINER=agent-gateway

# ─── Database (defaults work with docker-compose) ───────────
# POSTGRES_USER=tower
# POSTGRES_DB=tower
# DB_POOL_MIN_SIZE=2
# DB_POOL_MAX_SIZE=10
